  "item": [
    {
      "name": "0. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/bff/health/",
          "host": ["{{base_url}}"],
          "path": ["api", "bff", "health", ""]
        }
      },
      "response": []
    },
    {
      "name": "1. Get Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Token received\", function () {",
              "  pm.response.to.have.status(200);",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.access).to.exist;",
              "  pm.collectionVariables.set(\"access_token\", jsonData.access);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"client_1\",\n  \"password\": \"pass1234\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/token/",
          "host": ["{{base_url}}"],
          "path": ["api", "token", ""]
        }
      },
      "response": []
    },
    {
